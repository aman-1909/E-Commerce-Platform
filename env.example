# Copy this file to .env and fill in real values for production use.
# The project works out of the box without any of this because it defaults
# to an in-memory MongoDB and a Stripe stub in test mode (see README).

# If you have a real MongoDB, set this to switch away from in-memory mode:
# MONGO_URI=mongodb://localhost:27017/ecommerce

# JWT signing secret (a default dev secret is used if not set — change in production)
JWT_SECRET=super_secret_dev_key_change_me

# Stripe secret key (test mode). Get one free at https://dashboard.stripe.com/test/apikeys
# If left blank, checkout runs in "mock payment" mode and still works end-to-end.
STRIPE_SECRET_KEY=

PORT=5000
